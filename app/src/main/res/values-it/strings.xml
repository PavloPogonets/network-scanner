    <!-- Dialogs -->
    <string name="dialog_clear_cache_title">Cancellare la Cache?</string>
    <string name="dialog_clear_cache_message">Verranno cancellati tutti i dati di scansione temporanei. La cronologia dei dispositivi sarà preservata.</string>
    <string name="dialog_clear_history_title">Cancellare la Cronologia?</string>
    <string name="dialog_clear_history_message">Verranno rimosse tutte le informazioni salvate sui dispositivi, inclusi i nomi personalizzati. Questa azione è irreversibile.</string>
    <string name="dialog_about_title">Informazioni su Network Scanner</string>
    <string name="dialog_about_message" formatted="false">Network Scanner è un potente strumento per scoprire e analizzare i dispositivi sulla tua rete locale.\n\nSviluppato con cura per la tua privacy. Tutte le scansioni avvengono localmente sul tuo dispositivo.\n\n⚠️ Nota: il rilevamento dei dispositivi e la scansione delle porte non sono precisi al 100%. I risultati possono variare in base alle condizioni della rete e alle configurazioni dei dispositivi.\n\nVersione 1.0.0 | Licenza GPL-3.0</string>
    <string name="view_on_github">Vedi su GitHub</string>
    <string name="github_url">https://github.com/usamaiqb/network-scanner</string>
    <string name="deep_scan_disclaimer">Il rilevamento di porte e SO sono stime e potrebbero non essere completamente accurati</string>
    <string name="dialog_privacy_title">Informativa sulla Privacy</string>
    <string name="dialog_privacy_message">Network Scanner rispetta la tua privacy:\n\n• Nessuna raccolta dati: tutti i risultati della scansione rimangono sul tuo dispositivo\n• Nessuna pubblicità o tracciamento\n• Nessun permesso Internet richiesto per la scansione\n\nL\'autorizzazione di posizione viene utilizzata solo per accedere alle informazioni WiFi come richiesto da Android, non per tracciare la tua posizione.</string>
    <string name="dialog_theme_restart_title">Tema Cambiato</string>
    <string name="dialog_theme_restart_message">Le modifiche ai colori dinamici avranno effetto completo dopo il riavvio dell\'app.</string>

